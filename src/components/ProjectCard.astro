---
const { slug, name, category, short, image, tags = [] } = Astro.props;
const base = import.meta.env.BASE_URL;
const imgSrc = image ? `${base}${image.replace(/^\//, '')}` : null;
---

<a href={`${base}projects/${slug}`} class="project-card card">
  <div class="project-card-image">
    {imgSrc ? (
      <img src={imgSrc} alt={name} loading="lazy" />
    ) : (
      <div class="project-card-placeholder">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
      </div>
    )}
  </div>
  <div class="project-card-body">
    <span class="tag">{category}</span>
    <h3>{name}</h3>
    <p class="project-card-short">{short}</p>
    {tags.length > 0 && (
      <div class="project-card-tags">
        {tags.map(t => <span class="tech-tag">{t}</span>)}
      </div>
    )}
  </div>
</a>

<style>
  .project-card {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    color: inherit;
  }

  .project-card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--navy-light);
  }

  .project-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .project-card:hover .project-card-image img {
    transform: scale(1.05);
  }

  .project-card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-dim);
  }

  .project-card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .project-card-body h3 {
    font-size: 1.1rem;
    margin: 0;
  }

  .project-card-short {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.5;
  }

  .project-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }

  .tech-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    background: rgba(245, 242, 236, 0.04);
    color: var(--text-dim);
    border-radius: 4px;
  }
</style>
