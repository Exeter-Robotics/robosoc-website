---
import TopBar from '../components/TopBar.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title = 'RoboSoc', description = 'The Robotics Society at the University of Exeter. Building, programming, and competing with robots.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/jpeg" href={`${base}exrs_logo.jpg`} />
</head>
<body>
  <a href="#main" class="skip-link">Skip to content</a>
  <TopBar />
  <main id="main">
    <slot />
  </main>
  <Footer />
</body>
</html>

<style>
  main {
    padding-top: 64px;
    min-height: calc(100vh - 64px);
  }
</style>
