---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionDivider from '../components/SectionDivider.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Join | RoboSoc" description="Join RoboSoc, the Robotics Society at the University of Exeter.">
  <section class="section">
    <div class="container">
      <h1 class="page-title">Join RoboSoc</h1>
      <p class="page-intro">
        Whether you want to build robots, learn about autonomy, or just hang out with people who think robots are cool, you are welcome here.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top: 0;">
    <div class="container">
      <h2 class="section-title">Why join?</h2>
      <div class="reasons-grid">
        <div class="reason-card">
          <h3>Learn by building</h3>
          <p>Get hands-on experience with hardware and software that goes beyond coursework. Real robots, real code, real problems.</p>
        </div>
        <div class="reason-card">
          <h3>Meet your people</h3>
          <p>Connect with students across all years and departments who share your interest in robotics and engineering.</p>
        </div>
        <div class="reason-card">
          <h3>Build your portfolio</h3>
          <p>Contribute to open-source projects, compete in national competitions, and have something real to show employers.</p>
        </div>
        <div class="reason-card">
          <h3>No experience needed</h3>
          <p>Never touched a robot? Perfect. Our workshops start from the basics and we are always happy to help.</p>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  <section class="section">
    <div class="container">
      <h2 class="section-title">How to join</h2>
      <div class="steps">
        <div class="step">
          <span class="step-number">1</span>
          <div>
            <h3>Sign up on the Guild website</h3>
            <p>Register as a member through our <a href="https://my.exeterguild.com/groups/9264X/robotics-society" target="_blank" rel="noopener noreferrer">Exeter Guild page</a> to make it official. It is free.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-number">2</span>
          <div>
            <h3>Join our Discord</h3>
            <p>Hop into our <a href="https://discord.gg/H3HHrYE2wk" target="_blank" rel="noopener noreferrer">Discord server</a> to stay up to date with events and meet the team.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-number">3</span>
          <div>
            <h3>Show up</h3>
            <p>Come to a workshop, build night, or social. That is all it takes.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider />

  <section class="section">
    <div class="container">
      <h2 class="section-title">Get in touch</h2>
      <div class="contact-grid">
        <a href="https://discord.gg/H3HHrYE2wk" target="_blank" rel="noopener noreferrer" class="contact-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <span>Discord</span>
        </a>
        <a href="https://www.linkedin.com/company/exeter-robotics-society" target="_blank" rel="noopener noreferrer" class="contact-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          <span>LinkedIn</span>
        </a>
        <a href="https://github.com/Exeter-Robotics/" target="_blank" rel="noopener noreferrer" class="contact-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
          <span>GitHub</span>
        </a>
        <a href="https://fixr.co/organiser/111882605" target="_blank" rel="noopener noreferrer" class="contact-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <span>Fixr (Events)</span>
        </a>
        <a href="https://linktr.ee/robotics_exeter" target="_blank" rel="noopener noreferrer" class="contact-card">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="5 12 12 5 19 12"/><line x1="5" y1="19" x2="19" y2="19"/></svg>
          <span>Linktree</span>
        </a>
      </div>
    </div>
  </section>

  <SectionDivider />

  <section class="section">
    <div class="container">
      <h2 class="section-title">FAQ</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>Do I need any robotics experience?</summary>
          <p>Not at all. Many of our members had zero experience when they joined. We run beginner-friendly workshops and there is always someone willing to help you get started.</p>
        </details>
        <details class="faq-item">
          <summary>Do I need to be a Computer Science or Engineering student?</summary>
          <p>No. RoboSoc is open to students from any department. If you are interested in robots, you belong here.</p>
        </details>
        <details class="faq-item">
          <summary>Is there a membership fee?</summary>
          <p>Membership is free through the Exeter Students' Guild.</p>
        </details>
        <details class="faq-item">
          <summary>Do I need my own hardware?</summary>
          <p>No. We provide components, kits, and tools for workshops and build nights. Bring a laptop if you have one, but that is all.</p>
        </details>
        <details class="faq-item">
          <summary>How often do you meet?</summary>
          <p>We typically have at least one event per week during term time, ranging from workshops to build nights to socials. Check the events page for the latest schedule.</p>
        </details>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-title {
    margin-bottom: 1rem;
  }

  .page-intro {
    font-size: 1.1rem;
    color: var(--text-mid);
    max-width: 55ch;
  }

  .reasons-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 260px), 1fr));
    gap: 1.25rem;
  }

  .reason-card {
    background: var(--navy);
    border: 1px solid var(--border);
    border-radius: var(--card-radius);
    padding: 1.5rem;
  }

  .reason-card h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .reason-card p {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.5;
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .step {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .step-number {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--orange);
    background: var(--orange-soft);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step h3 {
    font-size: 1rem;
    margin-bottom: 0.25rem;
  }

  .step p {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.5;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 200px), 1fr));
    gap: 1rem;
  }

  .contact-card {
    background: var(--navy);
    border: 1px solid var(--border);
    border-radius: var(--card-radius);
    padding: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-mid);
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }

  .contact-card:hover {
    border-color: var(--orange);
    color: var(--orange);
  }

  .contact-card svg {
    flex-shrink: 0;
  }

  .contact-card span {
    font-size: 0.9rem;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    background: var(--navy);
    border: 1px solid var(--border);
    border-radius: var(--card-radius);
    overflow: hidden;
  }

  .faq-item summary {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text-strong);
    padding: 1rem 1.25rem;
    cursor: pointer;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .faq-item summary::after {
    content: '+';
    font-size: 1.25rem;
    color: var(--orange);
    transition: transform 0.2s;
  }

  .faq-item[open] summary::after {
    transform: rotate(45deg);
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item p {
    padding: 0 1.25rem 1rem;
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.6;
  }
</style>
