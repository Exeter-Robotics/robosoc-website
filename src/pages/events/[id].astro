---
import BaseLayout from '../../layouts/BaseLayout.astro';
import events from '../../data/events.json';

export function getStaticPaths() {
  return events.map(e => ({
    params: { id: String(e.id) },
    props: { event: e },
  }));
}

const { event } = Astro.props;
const base = import.meta.env.BASE_URL;
const imgSrc = event.image ? `${base}${event.image.replace(/^\//, '')}` : null;

const eventDate = new Date(event.date);
const formatted = eventDate.toLocaleDateString('en-GB', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const time = eventDate.toLocaleTimeString('en-GB', {
  hour: '2-digit',
  minute: '2-digit',
});
---

<BaseLayout title={`${event.title} | RoboSoc`} description={event.short}>
  <section class="section">
    <div class="container">
      <a href={`${base}events`} class="back-link">&larr; All events</a>

      <article class="event-detail">
        {imgSrc && (
          <div class="event-detail-image">
            <img src={imgSrc} alt={event.title} />
          </div>
        )}

        <div class="event-detail-body">
          <span class="tag">{event.tag}</span>
          <h1>{event.title}</h1>

          <div class="event-meta">
            <div class="meta-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>{formatted} at {time}</span>
            </div>
            <div class="meta-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>{event.location}</span>
            </div>
          </div>

          <div class="event-description">
            <p>{event.description}</p>
          </div>

          {event.signupUrl && (
            <a href={event.signupUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
              Sign up
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
            </a>
          )}
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .back-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    display: inline-block;
    margin-bottom: 2rem;
  }

  .back-link:hover {
    color: var(--orange);
  }

  .event-detail-image {
    border-radius: var(--card-radius);
    overflow: hidden;
    margin-bottom: 2rem;
    max-height: 400px;
  }

  .event-detail-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .event-detail-body h1 {
    margin: 0.75rem 0;
  }

  .event-meta {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin: 1.5rem 0;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-mid);
    font-size: 0.95rem;
  }

  .meta-item svg {
    color: var(--orange);
    flex-shrink: 0;
  }

  .event-description {
    margin-bottom: 2rem;
  }

  .event-description p {
    line-height: 1.7;
    max-width: 65ch;
  }
</style>
